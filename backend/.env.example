# Convex backend (set in Convex dashboard → Settings → Environment Variables)
CLERK_JWT_ISSUER_DOMAIN=https://....clerk.accounts.dev
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Identity `.convex.site` URL — server-side debits via /api/credits/*
IDENTITY_CONVEX_SITE_URL=
# Must match Identity Convex `CREDITS_SERVICE_SECRET_VIRGO`
CREDITS_SERVICE_SECRET_VIRGO=
# Set to "true" to deduct credits on paid actions. Unset or "false" skips debits.
CREDITS_ENFORCEMENT=
# Set to "true" to require Clerk auth for /summarize. Unset or "false" allows anonymous use.
REQUIRE_AUTH_FOR_SUMMARIZE=
